---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<nav class="footer-links">
			<a href="/audit.html">Shop</a>
			<a href="/blog">Blog</a>
			<a href="/about">About</a>
		</nav>
		<p class="copyright">&copy; {today.getFullYear()} SeamossInsider.com &mdash; All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		padding: 2em 1em;
		background: #1c2a2a;
		border-top: 2px solid #1d9e75;
		text-align: center;
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 24px;
		margin-bottom: 12px;
	}
	.footer-links a {
		color: #5dcaa5;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: 0.05em;
	}
	.footer-links a:hover {
		color: #9fe1cb;
	}
	.copyright {
		color: #9fe1cb;
		font-size: 0.85rem;
		margin: 0;
	}
</style>