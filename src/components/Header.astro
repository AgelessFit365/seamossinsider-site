---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo-link">
			<img src="/images/logo.png" alt="SeamossInsider" height="58" />
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/audit.html" class="shop-link">Shop</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: #1c2a2a;
		border-bottom: 3px solid #1d9e75;
		overflow: visible;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 110px;
	}
	.logo-link {
		display: flex;
		align-items: center;
		text-decoration: none;
	}
	nav a {
		padding: 1em 0.75em;
		color: #ffffff;
		border-bottom: 3px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		border-bottom-color: #5dcaa5;
		color: #5dcaa5;
	}
	.internal-links {
		display: flex;
		gap: 8px;
	}
</style>